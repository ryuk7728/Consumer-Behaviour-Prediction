PORT=7071
NODE_ENV=development
CORS_ORIGIN=*

# Leave blank for local in-memory mode.
# Fill these values to connect the app to Azure Cosmos DB.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=consumer_behavior
COSMOS_EVENTS_CONTAINER=events
COSMOS_PREDICTIONS_CONTAINER=predictions

# Optional:
# Set FORCE_IN_MEMORY=true only if you want to ignore Cosmos settings
# and run fully in local in-memory mode.
# FORCE_IN_MEMORY=true
